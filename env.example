# ═══════════════════════════════════════════════════════════
# MAHMOUD TRADING BOT v4 — FULL EDITION
# Environment Variables (نسخ في Railway → Variables)
# ═══════════════════════════════════════════════════════════

# ─── الأساسي (إجباري) ───
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
ETHERSCAN_KEY=YOUR_ETHERSCAN_API_KEY

# ─── قاعدة البيانات ───
# على Railway Pro + Volume mounted: استخدم /data/mahmoud_bot.db
# على Free tier: mahmoud_bot.db (تختفي عند redeploy!)
MAHMOUD_DB_PATH=mahmoud_bot.db

# ═══════════════════════════════════════════════════════════
# Wave 1 — News + Calendar (الأولوية الأولى)
# ═══════════════════════════════════════════════════════════

# Massive.com (Polygon.io سابقاً) — مصدر شامل للبيانات
# يستخدم في:
#   • Calendar: CPI + Treasury Yields + Inflation Expectations (Economy API)
#   • News: structured news مع sentiment + ticker tagging
# Dashboard: https://massive.com/dashboard/keys
MASSIVE_API_KEY=

# CoinMarketCal (لأحداث الكريبتو: token unlocks, listings)
# اختياري — مجاني تسجيل
# https://coinmarketcal.com/en/api
COINMARKETCAL_KEY=

# ═══════════════════════════════════════════════════════════
# Wave 2 — AI Brains (للتحليل الذكي)
# ═══════════════════════════════════════════════════════════

# Anthropic Claude (الأقوى للتحليل المالي)
# https://console.anthropic.com/
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Google Gemini (الأسرع — مجاني generous tier)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI GPT-4o (الأكثر شعبية)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ملاحظة: تقدر تشغل 1 أو 2 أو 3 — البوت يستخدم اللي متاح
# Multi-AI Consensus يحتاج على الأقل 2

# ═══════════════════════════════════════════════════════════
# Wave 3 — Whale Alert
# ═══════════════════════════════════════════════════════════

# Whale Alert (لتتبع التحويلات الكبيرة >$1M)
# اختياري — Free tier: 10 req/min
# https://docs.whale-alert.io/
WHALE_ALERT_KEY=
MIN_WHALE_USD=1000000

# ═══════════════════════════════════════════════════════════
# نصائح Railway:
# 1. Free Tier ❌ لا يحفظ DB عند redeploy
# 2. Pro Plan ($5/شهر) ✅ + Volume mount على /data
# 3. أضف Volume: Settings → Volumes → /data
# 4. ضع MAHMOUD_DB_PATH=/data/mahmoud_bot.db
# ═══════════════════════════════════════════════════════════
