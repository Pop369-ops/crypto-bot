# ═════════════════════════════════════════════
# MAHMOUD TRADING BOT v5 — ENVIRONMENT VARIABLES
# ═════════════════════════════════════════════

# ──────────────────────────────
# 🔴 إجباري (Required)
# ──────────────────────────────

# Telegram Bot Token من @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Etherscan API Key للـon-chain analysis
# https://etherscan.io/apis
ETHERSCAN_KEY=YOUR_ETHERSCAN_KEY


# ──────────────────────────────
# 🟡 موصى به (للأداء الكامل)
# ──────────────────────────────

# AI Verdict — لو موجود، AI يعطي رأي ترجيحي مع كل إشارة
# يكفي واحد فقط — رتّب الأفضلية: Claude > Gemini > OpenAI

# 1. Claude (الأذكى — مدفوع)
# https://console.anthropic.com/settings/keys
# CLAUDE_API_KEY=sk-ant-...

# 2. Gemini (مجاني! 1500 req/day)
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...

# 3. OpenAI (احتياطي)
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...


# ──────────────────────────────
# 🟢 اختياري (Optional)
# ──────────────────────────────

# Whale Alert — لتنبيهات الحركات الكبيرة على البلوكتشين
# https://docs.whale-alert.io/
# WHALE_ALERT_KEY=YOUR_KEY
# MIN_WHALE_USD=1000000


# ──────────────────────────────
# ⚙️ إعدادات متقدمة (لا تعدّلها إلا إذا تعرف)
# ──────────────────────────────

# مسار قاعدة البيانات (اتركها فارغة للـcwd)
# MAHMOUD_DB_PATH=mahmoud_bot.db

# نماذج AI (افتراضية — لا داعي للتغيير)
# CLAUDE_MODEL=claude-sonnet-4-5-20250929
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gpt-4o-mini
